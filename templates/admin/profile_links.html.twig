{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Все связи профиля «{{ profile.name }}»{% endblock %}

{% block main %}
<div class="profile-links">
    <p class="mb-3">
        <a href="{{ backUrl }}" class="btn btn-outline-secondary btn-sm"><i class="fa fa-arrow-left"></i> Назад к профилю</a>
    </p>
    {% if links is empty %}
        <p class="text-body-secondary">Нет связей (ни как тренер, ни как подопечный).</p>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Роль</th>
                        <th>Тренер</th>
                        <th>Подопечный</th>
                        <th>Отображаемое имя</th>
                        <th>Архив</th>
                        <th>Создан</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for link in links %}
                        <tr>
                            <td>
                                {% if link.coachProfile.id == profile.id %}
                                    <span class="badge bg-primary">Тренер</span>
                                {% else %}
                                    <span class="badge bg-secondary">Подопечный</span>
                                {% endif %}
                            </td>
                            <td>{{ link.coachProfile.name }} <small class="text-muted">({{ link.coachProfile.id|slice(0, 8) }}…)</small></td>
                            <td>{{ link.traineeProfile.name }} <small class="text-muted">({{ link.traineeProfile.id|slice(0, 8) }}…)</small></td>
                            <td>{{ link.displayName ?? '—' }}</td>
                            <td>{% if link.archived %}<span class="text-muted">В архиве</span>{% else %}—{% endif %}</td>
                            <td>{{ link.createdAt|date('d.m.Y H:i') }}</td>
                            <td>
                                <a href="{{ linkDetailUrls[link.id] ?? '#' }}" class="btn btn-sm btn-outline-primary">Открыть</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
